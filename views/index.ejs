<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
    <div class = "main w-full min-h-screen bg-zinc-900">
    <div class = "Forms p-10 text-white ">
        <form action = "/create" method = "post" >
            <input class = "block px-5 py-2 w-full rounded bg-zinc-800"  type="text" placeholder="Title goes here" name = "title">
            <textarea class = "block px-5 py-2 mt-2 w-full rounded resize-none bg-zinc-800 " placeholder="write your text in detail" name = "details"></textarea>
            <input class= "mt-2 bg-blue-600 px-5 py-2 rounded " type = "submit" value = "create task ">
        </div>
        <h3 class = "text-white p-10 ">Here is your tasks</h3>
    <div class = "task p-10 flex gap-3 flex-wrap" >
        <%if(files.length > 0){ %>
            <% files.forEach((filename) =>{ %>
        <div class = "task rounded w-72 px-5 py-4 bg-zinc-800">
        <h1 class=" text-white tracking-tighter "><%= filename %></h1>
         
        <a href="/files/<%= filename %> " class=" text-white tracking-tighter">see details</a>
      
          
        </div> 
        <% }) %>
         
        <% } else { %>
            <h3 class = "text-white px-5 py-4 bg-zinc-800 rounded ">no tasks</h3>
        <%}%>
        </div> 
    </div> 
    </div>
    </div>

</body>
</html> 